{
  "name": "leads-crm",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k \"bun --cwd server dev\" \"bun --cwd client dev\"",
    "dev:server": "bun --cwd server dev",
    "dev:client": "bun --cwd client dev",
    "start": "bun --cwd server start",
    "build": "bun --cwd client build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}